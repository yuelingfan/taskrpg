# 数据库连接（本地开发时直接配置；Docker 部署时通过 docker-compose.yml 自动注入）
DATABASE_URL=postgresql://user:password@localhost:5432/taskrpg

# Docker Compose 数据库配置
DB_USER=taskrpg
DB_PASSWORD=your-db-password
DB_NAME=taskrpg

# OpenAI / 兼容 API 配置
OPENAI_API_KEY=your-api-key-here

# 模型名称（OpenAI: gpt-4o；DeepSeek: deepseek-chat 等）
OPENAI_MODEL=gpt-4o

# Base URL（使用第三方兼容 API 时填写，如 https://api.deepseek.com）
# OPENAI_BASE_URL=https://api.openai.com/v1

# JWT Secret（生产环境必须修改为随机强密码）
JWT_SECRET=taskrpg-secret-key-change-in-production

# CORS 配置（生产环境可设为 * 或指定域名，如 https://your-domain.com）
# CORS_ORIGINS=*
